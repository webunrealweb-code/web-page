---
import '../styles/global.css';
import SiteJsonLd from '../components/seo/SiteJsonLd.astro';
import type { Lang } from '../i18n/types';

interface Props {
	title?: string;
	description?: string;
	lang?: Lang;
	ogLocale?: string;
	robots?: string;
	canonicalPath?: string;
	ogImagePath?: string;
	ogType?: 'website' | 'article';
	twitterSite?: string;
	skipLinkText?: string;
}

const {
	title = 'UnrealTalent',
	description = 'Unreal Connections— website coming soon.',
	lang = 'en',
	ogLocale,
	robots = 'index, follow',
	canonicalPath,
	ogImagePath,
	ogType = 'website',
	twitterSite,
	skipLinkText = 'Skip to main content',
} = Astro.props;

const site = Astro.site;
const path = canonicalPath ?? Astro.url.pathname;
const canonical = site ? new URL(path, site).href : undefined;
const ogImage =
	site && ogImagePath ? new URL(ogImagePath.startsWith('/') ? ogImagePath : `/${ogImagePath}`, site).href : undefined;
const twitterCard = ogImage ? 'summary_large_image' : 'summary';

const htmlLang = lang === 'es' ? 'es' : 'en';
const ogLocaleFinal = ogLocale ?? (lang === 'es' ? 'es_ES' : 'en_US');
const altLocale = lang === 'en' ? 'es_ES' : 'en_US';
const altLang = lang === 'en' ? 'es' : 'en';
const altPath = lang === 'en' ? '/es/' : '/en/';
const altHref = site ? new URL(altPath, site).href : undefined;
const defaultLangHref = site ? new URL('/en/', site).href : undefined;
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<meta charset="utf-8" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400..700;1,9..40,400..700&family=Syne:wght@500..800&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content={robots} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#2450f9" />
		<title>{title}</title>
		{canonical && <link rel="canonical" href={canonical} />}
		{canonical && altHref && defaultLangHref && (
			<>
				<link rel="alternate" hreflang={htmlLang} href={canonical} />
				<link rel="alternate" hreflang={altLang} href={altHref} />
				<link rel="alternate" hreflang="x-default" href={defaultLangHref} />
			</>
		)}
		<meta property="og:site_name" content="UnrealTalent" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:locale" content={ogLocaleFinal} />
		{altHref && <meta property="og:locale:alternate" content={altLocale} />}
		{canonical && <meta property="og:url" content={canonical} />}
		{ogImage && <meta property="og:image" content={ogImage} />}
		<meta name="twitter:card" content={twitterCard} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{twitterSite && <meta name="twitter:site" content={`@${twitterSite}`} />}
		{ogImage && <meta name="twitter:image" content={ogImage} />}
		<SiteJsonLd inLanguage={htmlLang} />
	</head>
	<body>
		<a
			class="absolute left-3 top-3 z-[9999] -translate-y-[150%] rounded bg-ut-cinder px-4 py-3 font-semibold text-slate-50 no-underline transition-transform duration-150 focus:translate-y-0 focus-visible:translate-y-0 focus-visible:outline-none"
			href="#main-content">{skipLinkText}</a>
		<slot />
	</body>
</html>
