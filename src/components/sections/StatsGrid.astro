---
interface Stat {
	value: string;
	label: string;
}

interface Props {
	stats: readonly Stat[];
	ariaLabel: string;
}

const { stats, ariaLabel } = Astro.props;
---

<section
	class="w-full bg-gradient-to-r from-ut-mulled to-ut-scampi text-slate-50 scroll-mt-20"
	aria-label={ariaLabel}
>
	<div class="mx-auto max-w-[72rem] px-[clamp(1rem,4vw,2rem)] py-[clamp(2rem,5vw,3rem)]">
		<ul class="m-0 grid list-none grid-cols-2 gap-x-4 gap-y-7 p-0 text-center md:grid-cols-4 md:gap-8">
			{
				stats.map((s) => (
					<li class="m-0 p-0">
						<p class="m-0 mb-1 font-display text-[clamp(2.25rem,6vw,3.5rem)] font-extrabold leading-none tracking-tight text-white">
							{s.value}
						</p>
						<p class="m-0 text-xs font-bold uppercase leading-snug tracking-wide text-slate-100/90">
							{s.label}
						</p>
					</li>
				))
			}
		</ul>
	</div>
</section>
