---
export interface StatRow {
	readonly stat: string;
	readonly label: string;
}

interface Props {
	stats: readonly StatRow[];
	ariaLabel: string;
}

const { stats, ariaLabel } = Astro.props;
---

<section
	class="w-full bg-gradient-to-r from-ut-mulled to-ut-scampi text-slate-50 scroll-mt-20"
	aria-label={ariaLabel}
>
	<div class="w-fit mx-auto max-w-[72rem] px-[clamp(1rem,4vw,2rem)] py-[clamp(2rem,5vw,3rem)]">
		<ul class="m-0 flex list-none flex-col gap-7 p-0 md:flex-row md:items-center md:justify-center md:gap-8">
			{
				stats.map((row) => (
					<li class="m-0 flex flex-row flex-wrap items-center justify-center gap-x-2 gap-y-1 p-0 sm:gap-x-3 md:flex-1">
						<p class="m-0 shrink-0 font-display text-[clamp(2rem,5.5vw,3.25rem)] font-extrabold leading-none tracking-tight text-white">
							{row.stat}
						</p>
						<p class="m-0 text-center text-lg font-bold uppercase leading-snug tracking-wide text-slate-100/90 sm:text-left">
							{row.label}
						</p>
					</li>
				))
			}
		</ul>
	</div>
</section>
