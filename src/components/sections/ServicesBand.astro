---
import SectionHeading from './SectionHeading.astro';
import TalentCard from './TalentCard.astro';
import type { Messages, ServiceIconKey } from '../../i18n/types';
import talentManagementIcon from '../../assets/services/talent-management.svg';
import brandPartnershipsIcon from '../../assets/services/brand-partnerships.svg';
import productionIcon from '../../assets/services/production.svg';
import creativeDevelopmentIcon from '../../assets/services/creative-development.svg';
import eventsExperiencesIcon from '../../assets/services/events-experiences.svg';
import strategicConsultingIcon from '../../assets/services/strategic-consulting.svg';

interface Talent {
	name: string;
	tags: readonly string[];
	image?: string;
}

interface Props {
	talents: readonly Talent[];
	messages: Messages;
}

const { talents, messages } = Astro.props;
const t = messages.services;
const serviceIcons: Record<ServiceIconKey, string> = {
	'talent-management': talentManagementIcon.src,
	'brand-partnerships': brandPartnershipsIcon.src,
	production: productionIcon.src,
	'creative-development': creativeDevelopmentIcon.src,
	'events-experiences': eventsExperiencesIcon.src,
	'strategic-consulting': strategicConsultingIcon.src,
};
---

<section class="w-full scroll-mt-20 bg-ut-cinder text-slate-50" id="services" aria-labelledby="services-heading">
	<div
		class="mx-auto max-w-[72rem] px-[clamp(1rem,4vw,2rem)] pt-[clamp(1.25rem,3vw,2rem)] pb-[clamp(3rem,8vw,5rem)]"
	>
		<SectionHeading
			id="services-heading"
			title={t.title}
			subtitle={t.subtitle}
			accent
			display
			scheme="dark"
			align="left"
		/>

		<div class="mb-12 grid gap-10 md:grid-cols-2">
			{t.services.map((service) => (
				<div class="flex items-center gap-4">
					<img
						src={serviceIcons[service.icon]}
						alt=""
						aria-hidden="true"
						class="h-full max-h-24 w-auto shrink-0 self-stretch"
						loading="lazy"
						decoding="async"
					/>
					<div class="min-w-0">
						<h3 class="mb-3 font-sans text-[0.875rem] font-bold uppercase tracking-wide text-ut-scampi sm:text-[0.9375rem]">{service.title}</h3>
						<p class="m-0 leading-relaxed text-slate-200/85">{service.body}</p>
					</div>
				</div>
			))}
		</div>

		<h3 class="mb-2 font-display text-2xl font-extrabold uppercase tracking-wide text-white" id="talent">
			{t.rosterTitle}
		</h3>
		<p class="mb-8 max-w-[36rem] text-[0.9375rem] leading-relaxed text-slate-300/85">
			{t.rosterLead}
		</p>
		<p class="mb-8">
			<a
				href="#contact"
				class="font-sans text-sm font-semibold text-ut-scampi underline underline-offset-4 transition hover:text-ut-accent-hover focus-visible:outline-none focus-visible:[box-shadow:0_0_0_2px_var(--color-ut-bg),0_0_0_4px_var(--color-ut-scampi)]"
			>
				{t.rosterContactCta}
			</a>
		</p>
		<ul class="m-0 grid list-none grid-cols-1 gap-4 p-0 sm:grid-cols-2 lg:grid-cols-3">
			{talents.map((tal) => <TalentCard name={tal.name} tags={tal.tags} image={tal.image ?? ''} />)}
		</ul>
	</div>
</section>
