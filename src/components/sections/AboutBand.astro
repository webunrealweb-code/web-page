---
import SectionHeading from './SectionHeading.astro';
import type { Messages } from '../../i18n/types';
import missionRocketIcon from '../../assets/about/mission-rocket.svg';
import visionEyeIcon from '../../assets/about/vision-eye.svg';

interface Props {
	messages: Messages;
}

const { messages } = Astro.props;
const t = messages.about;
---

<section class="w-full scroll-mt-20 bg-ut-cinder text-slate-50" id="about" aria-labelledby="about-heading">
	<div class="mx-auto max-w-[72rem] px-[clamp(1rem,4vw,2rem)] py-[clamp(3rem,8vw,5rem)]">
		<SectionHeading
			id="about-heading"
			title={t.title}
			subtitle={t.subtitle}
			subtitleFullWidth
			accent
			display
			scheme="dark"
			align="left"
		/>
		<div class="mb-12 grid gap-8 md:grid-cols-2 md:gap-x-10">
			<div class="flex items-center gap-4">
				<img
					src={missionRocketIcon.src}
					alt=""
					aria-hidden="true"
					class="h-16 w-16 shrink-0 self-center object-contain sm:h-20 sm:w-20"
					loading="lazy"
					decoding="async"
				/>
				<div class="min-w-0">
					<h3 class="mb-3 font-sans text-[0.875rem] font-bold uppercase tracking-wide text-ut-scampi sm:text-[0.9375rem]">{t.missionTitle}</h3>
					<p class="m-0 leading-relaxed text-slate-200/90">{t.missionBody}</p>
				</div>
			</div>
			<div class="flex items-center gap-4">
				<img
					src={visionEyeIcon.src}
					alt=""
					aria-hidden="true"
					class="h-16 w-16 shrink-0 self-center object-contain sm:h-20 sm:w-20"
					loading="lazy"
					decoding="async"
				/>
				<div class="min-w-0">
					<h3 class="mb-3 font-sans text-[0.875rem] font-bold uppercase tracking-wide text-ut-scampi sm:text-[0.9375rem]">{t.visionTitle}</h3>
					<p class="m-0 leading-relaxed text-slate-200/90">{t.visionBody}</p>
				</div>
			</div>
		</div>
	</div>
</section>
