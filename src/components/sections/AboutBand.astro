---
import SectionHeading from './SectionHeading.astro';
import type { Messages } from '../../i18n/types';

interface Props {
	messages: Messages;
}

const { messages } = Astro.props;
const t = messages.about;
---

<section class="w-full scroll-mt-20 bg-ut-cinder text-slate-50" id="about" aria-labelledby="about-heading">
	<div class="mx-auto max-w-[72rem] px-[clamp(1rem,4vw,2rem)] py-[clamp(3rem,8vw,5rem)]">
		<SectionHeading
			id="about-heading"
			title={t.title}
			subtitle={t.subtitle}
			accent
			display
			scheme="dark"
			align="left"
		/>
		<div class="mb-12 grid gap-8 md:grid-cols-2 md:gap-x-10">
			<div class="flex items-center gap-4">
				<img
					src="/images/about/mission-rocket.svg"
					alt=""
					aria-hidden="true"
					class="h-full max-h-24 w-auto shrink-0 self-stretch"
					loading="lazy"
					decoding="async"
				/>
				<div>
					<h3 class="mb-2.5 font-sans text-xs font-bold uppercase tracking-wide text-ut-pixel-a">{t.missionTitle}</h3>
					<p class="m-0 leading-relaxed text-slate-200/90">{t.missionBody}</p>
				</div>
			</div>
			<div class="flex items-center gap-4">
				<img
					src="/images/about/vision-eye.svg"
					alt=""
					aria-hidden="true"
					class="h-full max-h-24 w-auto shrink-0 self-stretch"
					loading="lazy"
					decoding="async"
				/>
				<div>
					<h3 class="mb-2.5 font-sans text-xs font-bold uppercase tracking-wide text-ut-pixel-a">{t.visionTitle}</h3>
					<p class="m-0 leading-relaxed text-slate-200/90">{t.visionBody}</p>
				</div>
			</div>
		</div>
	</div>
</section>
