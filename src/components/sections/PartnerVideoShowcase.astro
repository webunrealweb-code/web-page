---
import type { PartnerVideoRow } from '../../i18n/types';
import Video from '../Video.astro';

interface Props {
	videos: readonly PartnerVideoRow[];
	ariaLabel: string;
}

const { videos, ariaLabel } = Astro.props;
const hasControls = videos.length > 1;
---

<div
	class="mt-1"
	role="region"
	aria-label={ariaLabel}
>
	<div class="relative" data-video-carousel tabindex="0">
		<div class="overflow-hidden px-1 sm:px-2">
			<ul class="flex transition-transform duration-300 ease-out" data-carousel-track>
				{
					videos.map((v, i) => (
						<li class="w-full shrink-0 px-1 sm:w-1/2 lg:w-1/3" aria-hidden={i === 0 ? 'false' : 'true'} data-carousel-slide>
							<article class="mx-auto flex w-full min-w-0 max-w-[20rem] flex-col gap-4 sm:max-w-[18rem] lg:max-w-[20rem]">
								<div class="relative mx-auto flex aspect-[9/16] w-full max-w-[17.5rem] min-h-0 flex-col overflow-hidden rounded-lg bg-black/35 shadow-[0_0_0_1px_rgba(106,101,177,0.28),0_18px_40px_rgba(4,4,7,0.45)] [max-height:min(76vh,44rem)] before:pointer-events-none before:absolute before:inset-x-0 before:top-0 before:z-[2] before:h-[3px] before:bg-gradient-to-r before:from-ut-scampi before:to-ut-mulled">
									<Video src={v.videoSrc} title={v.title} fillParent />
								</div>
								<div class="px-0.5 text-left">
									<p class="mb-1 text-[0.6875rem] font-bold uppercase tracking-wide text-ut-scampi">{v.partner}</p>
									<h3 class="mb-1 font-sans text-base font-bold leading-snug tracking-tight text-slate-50">{v.headline}</h3>
									{v.description ? <p class="m-0 text-sm leading-relaxed text-slate-200/80">{v.description}</p> : null}
								</div>
							</article>
						</li>
					))
				}
			</ul>
		</div>

		{
			hasControls && (
				<div class="pointer-events-none absolute inset-x-0 top-1/2 z-20 flex -translate-y-1/2 items-center justify-between px-1 sm:px-3">
					<button
						type="button"
						class="pointer-events-auto inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/45 bg-black/45 text-white backdrop-blur-sm transition hover:bg-black/65 focus-visible:outline-none focus-visible:[box-shadow:0_0_0_2px_#fff,0_0_0_4px_var(--color-ut-scampi)] disabled:cursor-default disabled:border-white/20 disabled:bg-black/15 disabled:text-white/30 disabled:shadow-none"
						data-carousel-prev
						aria-label="Previous video"
					>
						<span aria-hidden="true">‹</span>
					</button>
					<button
						type="button"
						class="pointer-events-auto inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/45 bg-black/45 text-white backdrop-blur-sm transition hover:bg-black/65 focus-visible:outline-none focus-visible:[box-shadow:0_0_0_2px_#fff,0_0_0_4px_var(--color-ut-scampi)] disabled:cursor-default disabled:border-white/20 disabled:bg-black/15 disabled:text-white/30 disabled:shadow-none"
						data-carousel-next
						aria-label="Next video"
					>
						<span aria-hidden="true">›</span>
					</button>
				</div>
			)
		}

	</div>
</div>

{
	hasControls && (
		<script type="module">
			for (const carousel of document.querySelectorAll('[data-video-carousel]')) {
				const track = carousel.querySelector('[data-carousel-track]');
				const slides = Array.from(carousel.querySelectorAll('[data-carousel-slide]'));
				const prev = carousel.querySelector('[data-carousel-prev]');
				const next = carousel.querySelector('[data-carousel-next]');

				if (!track || !prev || !next || slides.length < 2) continue;

				let index = 0;
				let visibleCount = 1;

				const getVisibleCount = () => {
					if (window.matchMedia('(min-width: 1024px)').matches) return 3;
					if (window.matchMedia('(min-width: 640px)').matches) return 2;
					return 1;
				};
				const getMaxIndex = () => Math.max(0, slides.length - visibleCount);

				const update = () => {
					visibleCount = getVisibleCount();
					const maxIndex = getMaxIndex();
					if (index > maxIndex) index = maxIndex;

					track.style.transform = `translateX(-${index * (100 / visibleCount)}%)`;

					const canNavigate = slides.length > visibleCount;
					prev.hidden = !canNavigate;
					next.hidden = !canNavigate;
					prev.disabled = !canNavigate || index === 0;
					next.disabled = !canNavigate || index >= maxIndex;

					for (const [i, slide] of slides.entries()) {
						const isVisible = i >= index && i < index + visibleCount;
						slide.setAttribute('aria-hidden', isVisible ? 'false' : 'true');
					}
				};

				prev.addEventListener('click', () => {
					const maxIndex = getMaxIndex();
					if (maxIndex <= 0) return;
					if (index > 0) index -= 1;
					update();
				});

				next.addEventListener('click', () => {
					const maxIndex = getMaxIndex();
					if (maxIndex <= 0) return;
					if (index < maxIndex) index += 1;
					update();
				});

				carousel.addEventListener('keydown', (event) => {
					if (event.key === 'ArrowLeft') prev.click();
					if (event.key === 'ArrowRight') next.click();
				});

				window.addEventListener('resize', update);
				update();
			}
		</script>
	)
}
