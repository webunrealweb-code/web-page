---
import { Image } from 'astro:assets';
import Button from '../Button.astro';
import mainLogo from '../../assets/brand/Isotipo Blanco.png';
import type { Lang } from '../../i18n/types';
import type { Messages } from '../../i18n/types';
import { href } from '../../i18n/paths';

interface Props {
	lang: Lang;
	messages: Messages;
}

const { lang, messages } = Astro.props;
const t = messages.hero;
---

<section
	class="relative flex min-h-[min(92vh,52rem)] items-center justify-center overflow-hidden bg-gradient-to-br from-ut-cinder via-ut-mulled to-ut-mulled scroll-mt-20"
	id="hero"
	aria-labelledby="hero-heading"
>
	<div
		class="relative mx-auto max-w-[52rem] px-6 sm:px-[clamp(1rem,4vw,2rem)] pb-[clamp(3rem,10vh,5rem)] pt-[clamp(5.5rem,14vh,8rem)] text-center"
	>
		<Image
			src={mainLogo}
			alt={messages.a11y.brandLogo}
			class="mx-auto mb-6 h-auto w-full max-w-[14rem] object-contain sm:max-w-[16.5rem] md:max-w-[18.5rem]"
			widths={[220, 320, 460, 620]}
			sizes="(max-width: 640px) 64vw, (max-width: 1024px) 340px, 420px"
			format="png"
			loading="eager"
		/>
		<p class="mb-4 px-2 text-center text-xs font-bold uppercase tracking-[0.08em] text-ut-hero-tonal sm:px-0">{t.eyebrow}</p>
		<div class="mb-4 px-2 sm:px-1">
			<h1
				id="hero-heading"
				class="mx-auto w-full max-w-[22rem] text-center font-display text-[clamp(1.45rem,5.2vw,3rem)] font-bold uppercase leading-snug tracking-wide text-white [text-wrap:balance] md:max-w-[60rem]"
			>
				{t.title}
			</h1>
		</div>
		<p
			class="mx-auto mb-8 max-w-[32rem] sm:max-w-[60rem] px-2 text-center text-[clamp(1rem,2.2vw,1.2rem)] leading-relaxed text-slate-100/90 sm:px-0"
		>
			{t.lead}
		</p>
		<div class="flex flex-wrap justify-center gap-3">
			<Button href={href(lang, '#talent')} variant="primary" class="rounded-full px-7 text-xs font-semibold uppercase tracking-wide">
				{t.ctaTalent}
			</Button>
			<Button href={href(lang, '#contact')} variant="heroGhost" class="px-7 text-xs font-semibold uppercase tracking-wide">
				{t.ctaContact}
			</Button>
		</div>
	</div>
</section>
