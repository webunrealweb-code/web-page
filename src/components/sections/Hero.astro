---
import { Image } from 'astro:assets';
import Button from '../Button.astro';
import invertedLogo from '../../assets/brand/UNREAL Inverted Color.png';
import type { Lang } from '../../i18n/types';
import type { Messages } from '../../i18n/types';
import { href } from '../../i18n/paths';

interface Props {
	lang: Lang;
	messages: Messages;
}

const { lang, messages } = Astro.props;
const t = messages.hero;
---

<section
	class="relative flex min-h-[min(92vh,52rem)] items-center justify-center overflow-hidden bg-gradient-to-br from-ut-cinder via-ut-mulled to-ut-mulled scroll-mt-20"
	id="hero"
	aria-labelledby="hero-heading"
>
	<div
		class="relative mx-auto max-w-[52rem] px-[clamp(1rem,4vw,2rem)] pb-[clamp(3rem,10vh,5rem)] pt-[clamp(5.5rem,14vh,8rem)] text-center"
	>
		<Image
			src={invertedLogo}
			alt={messages.a11y.brandLogo}
			class="mx-auto mb-6 h-auto w-full max-w-[14rem] object-contain sm:max-w-[16.5rem] md:max-w-[18.5rem]"
			widths={[220, 320, 460, 620]}
			sizes="(max-width: 640px) 64vw, (max-width: 1024px) 340px, 420px"
			format="png"
			loading="eager"
		/>
		<p class="mb-4 text-xs font-bold uppercase tracking-[0.08em] text-ut-hero-tonal">{t.eyebrow}</p>
		<h1
			id="hero-heading"
			class="mb-4 font-display text-[clamp(2.35rem,8vw,4.25rem)] font-extrabold uppercase leading-[1.02] tracking-[0.01em] text-balance text-white"
		>
			{t.title}
		</h1>
		<p
			class="mx-auto mb-8 max-w-[32rem] text-[clamp(1rem,2.2vw,1.2rem)] leading-relaxed text-slate-100/90"
		>
			{t.lead}
		</p>
		<div class="flex flex-wrap justify-center gap-3">
			<Button href={href(lang, '#talent')} variant="primary" class="rounded-full px-7 text-xs font-semibold uppercase tracking-wide">
				{t.ctaTalent}
			</Button>
			<Button href={href(lang, '#contact')} variant="heroGhost" class="px-7 text-xs font-semibold uppercase tracking-wide">
				{t.ctaContact}
			</Button>
		</div>
	</div>
</section>
