---
interface Props {
	name: string;
	tags: readonly string[];
	href?: string;
}

const { name, tags, href } = Astro.props;
---

<li class="relative aspect-[3/4] list-none overflow-hidden bg-ut-cinder p-0">
	<div
		class="pointer-events-none absolute left-3 top-3 z-[2] size-7 border-l-[3px] border-t-[3px] border-ut-pixel-a"
		aria-hidden="true"
	>
	</div>
	<div
		class="pointer-events-none absolute bottom-3 right-3 z-[2] size-7 border-b-[3px] border-r-[3px] border-ut-pixel-b"
		aria-hidden="true"
	>
	</div>
	<div
		class="absolute inset-0 bg-[linear-gradient(160deg,rgba(106,101,177,0.35)_0%,transparent_45%),linear-gradient(135deg,var(--color-ut-mulled)_0%,var(--color-ut-cinder)_50%,#1a1830_100%)]"
		aria-hidden="true"
	>
	</div>
	<div
		class="absolute inset-0 z-[1] flex flex-col justify-end bg-gradient-to-t from-[rgba(4,4,7,0.92)] via-transparent to-transparent px-[1.1rem] pb-[1.15rem] pt-16"
	>
		<p class="mb-1 text-[0.6875rem] font-semibold uppercase tracking-wide text-slate-100/75">{tags.join(' · ')}</p>
		{
			href ? (
				<a href={href} class="group/name text-inherit no-underline">
					<h4 class="m-0 font-display text-[1.0625rem] font-extrabold uppercase tracking-wide text-white group-hover/name:text-ut-pixel-a">
						{name}
					</h4>
				</a>
			) : (
				<h4 class="m-0 font-display text-[1.0625rem] font-extrabold uppercase tracking-wide text-white">{name}</h4>
			)
		}
	</div>
</li>
