---
import type { BrandLogo } from '../../data/brandLogos';
import type { Messages, PartnerVideoRow } from '../../i18n/types';
import BrandLogoCarousel from './BrandLogoCarousel.astro';
import SectionHeading from './SectionHeading.astro';
import PartnerVideoShowcase from './PartnerVideoShowcase.astro';

interface Props {
	brandLogos: readonly BrandLogo[];
	messages: Messages;
	partnerVideos: readonly PartnerVideoRow[];
}

const { brandLogos, messages, partnerVideos } = Astro.props;
const t = messages.partners;
---

<section class="w-full" aria-label={t.regionLabel}>
	<div class="w-full bg-ut-mist text-ut-cinder">
		<div class="mx-auto max-w-[72rem] px-[clamp(1rem,4vw,2rem)] py-[clamp(2.75rem,7vw,4.5rem)]">
			<h2
				id="partners-heading"
				class="mb-3 max-w-[48rem] font-display text-[clamp(1.75rem,4vw,2.75rem)] font-extrabold uppercase leading-tight tracking-wide text-ut-cinder"
			>
				{t.title}
			</h2>
			<p class="mb-8 max-w-[40rem] leading-relaxed text-ut-mulled">{t.lead}</p>
			<div
				class="rounded-2xl border border-ut-cinder/10 bg-ut-cinder px-3 pb-10 pt-8 text-slate-50 shadow-[0_24px_60px_rgba(4,4,7,0.18)] sm:px-6 md:px-10"
			>
				<p class="mb-6 text-xs font-bold uppercase tracking-[0.14em] text-slate-400">{t.logoStripTitle}</p>
				<div class="mb-8 flex flex-col items-center gap-0">
					<span
						class="font-display text-[clamp(0.95rem,3.2vw,2.15rem)] font-extrabold uppercase leading-[1.05] tracking-[0.08em] text-white"
					>
						{t.clientsHeadline}
					</span>
					<span
						class="font-display text-[clamp(0.95rem,3.2vw,2.15rem)] font-extrabold uppercase leading-[1.05] tracking-[0.08em] text-transparent [-webkit-text-stroke:1px_rgba(255,255,255,0.88)]"
						aria-hidden="true"
					>
						{t.clientsHeadline}
					</span>
				</div>
				<BrandLogoCarousel logos={brandLogos} ariaLabel={t.clientsCarouselLabel} />
			</div>
		</div>
	</div>

	<div class="w-full scroll-mt-20 bg-ut-cinder text-slate-50" id="partner-campaigns">
		<div class="mx-auto max-w-[72rem] px-[clamp(1rem,4vw,2rem)] py-[clamp(3rem,8vw,4.5rem)]">
			<SectionHeading
				title={t.workTitle}
				subtitle={t.workSubtitle}
				accent
				display
				scheme="dark"
				align="left"
			/>
			<PartnerVideoShowcase videos={partnerVideos} ariaLabel={messages.a11y.showcaseRegion} />
		</div>
	</div>
</section>
