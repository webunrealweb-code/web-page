---
import { socialProfiles } from '../../data/social';

interface Props {
	variant?: 'header' | 'footer';
	ariaLabel: string;
}

const { variant = 'footer', ariaLabel } = Astro.props;

const items = [
	{ name: 'Facebook', href: socialProfiles.facebook },
	{ name: 'Instagram', href: socialProfiles.instagram },
	{ name: 'TikTok', href: socialProfiles.tiktok },
] as const;

const linkBase =
	'inline-flex size-10 items-center justify-center rounded-md no-underline transition-colors duration-150 focus-visible:outline-none';
const linkHeader =
	'size-[2.35rem] text-slate-100/90 hover:bg-white/10 hover:text-white focus-visible:shadow-[var(--shadow-focus)]';
const linkFooter =
	'text-slate-300 hover:bg-ut-scampi/20 hover:text-white focus-visible:shadow-[var(--shadow-focus)]';
---

<ul
	class:list={[
		'm-0 flex list-none flex-wrap items-center gap-x-2 gap-y-1 p-0',
		variant === 'header' && 'gap-x-1.5',
	]}
	aria-label={ariaLabel}
>
	{
		items.map(({ name, href }) => (
			<li class="m-0 p-0">
				<a
					class:list={[linkBase, variant === 'header' ? linkHeader : linkFooter]}
					href={href}
					rel="noopener noreferrer"
					target="_blank"
					aria-label={name}
				>
					{name === 'Facebook' && (
						<svg class="block size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
							<path
								fill="currentColor"
								d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073c0 5.996 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.413c0-3.002 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
							/>
						</svg>
					)}
					{name === 'Instagram' && (
						<svg class="block size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
							<path
								fill="currentColor"
								d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.354 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.667.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 11-2.881.001 1.44 1.44 0 012.881-.001z"
							/>
						</svg>
					)}
					{name === 'TikTok' && (
						<svg class="block size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
							<path
								fill="currentColor"
								d="M12.525.02c1.31-.02 2.61-.01 3.931-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.55-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48.04 2.96-.04 4.44-.82-.22-1.72-.14-2.48.28-.76.43-1.35 1.17-1.67 1.98-.49 1.16-.42 2.55.07 3.69.51 1.09 1.51 1.95 2.67 2.33.81.27 1.69.33 2.54.22 1.09-.15 2.12-.71 2.81-1.61.17-.22.34-.45.48-.69.38-.73.55-1.55.52-2.36-.02-2.86 0-5.72-.02-8.58-.04-1.43-.41-2.85-1.12-4.07-.7-1.2-1.76-2.19-2.98-2.85-1.15-.56-2.45-.84-3.75-.75z"
							/>
						</svg>
					)}
				</a>
			</li>
		))
	}
</ul>
