---
import { Image } from 'astro:assets';
import logo from '../../assets/brand/Logotipo Blanco.png';
import type { Lang } from '../../i18n/types';
import type { Messages } from '../../i18n/types';
import { href, homePath, otherLang } from '../../i18n/paths';
import SocialLinks from './SocialLinks.astro';

interface Props {
	lang: Lang;
	messages: Messages;
}

const { lang, messages } = Astro.props;
const t = messages.nav;
const a = messages.a11y;
const alt = otherLang(lang);
const langToggleLabel = lang === 'en' ? 'ES' : 'EN';
const menuId = `site-menu-${lang}`;
const links = [
	{ href: href(lang, '#about'), label: t.about },
	{ href: href(lang, '#services'), label: t.services },
	{ href: href(lang, '#partner-campaigns'), label: t.partnersWork },
	{ href: href(lang, '#contact'), label: t.contact },
] as const;
---

<header
	data-site-header
	class="fixed inset-x-0 top-0 z-[100] border-b border-ut-bg/10 bg-ut-cinder/72 font-sans backdrop-blur-md"
>
	<div
		class="mx-auto flex min-h-[3.75rem] max-w-[72rem] items-center justify-between gap-4 px-[clamp(1rem,4vw,2rem)] py-2.5 sm:py-0"
	>
		<a
			href={homePath(lang)}
			class="inline-flex shrink-0 items-center leading-none text-ut-bg no-underline transition-opacity hover:opacity-90"
		>
			<Image
				src={logo}
				alt={a.brandLogo}
				class="h-10 w-auto max-w-[13.5rem] object-contain sm:h-11 sm:max-w-[16rem] md:h-12 md:max-w-[19rem]"
				widths={[220, 320, 460, 620]}
				sizes="(max-width: 640px) 180px, (max-width: 1024px) 240px, 300px"
				format="png"
				loading="eager"
			/>
		</a>

		<button
			type="button"
			class="mobile-menu-button inline-flex min-h-11 min-w-11 items-center justify-center rounded-md border border-ut-bg/20 bg-ut-bg/5 text-ut-bg transition hover:border-ut-bg/40 hover:bg-ut-bg/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ut-scampi lg:hidden"
			aria-controls={menuId}
			aria-expanded="false"
			aria-label={a.menuOpen}
			data-mobile-menu-button
			data-open-label={a.menuOpen}
			data-close-label={a.menuClose}
		>
			<span class="sr-only">{a.menuToggle}</span>
			<span class="menu-button-icon" aria-hidden="true">
				<span></span>
				<span></span>
				<span></span>
			</span>
		</button>

		<div class="hidden flex-wrap items-center justify-end gap-3 md:gap-5 lg:flex">
			<nav aria-label={a.navPrimary}>
				<ul class="m-0 flex list-none flex-wrap justify-end gap-x-5 gap-y-1 p-0">
					{
						links.map(({ href: h, label }) => (
							<li>
								<a
									class="border-b-2 border-transparent pb-0.5 text-xs font-semibold uppercase tracking-wide text-ut-bg/80 no-underline hover:border-ut-scampi hover:text-ut-bg focus-visible:border-ut-scampi"
									href={h}
								>
									{label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>
			<div class="flex flex-wrap items-center gap-3 border-l border-white/15 pl-3 max-sm:border-0 max-sm:pl-0">
				<a
					class="text-[0.75rem] font-semibold uppercase tracking-wide text-ut-hero-tonal no-underline hover:text-ut-bg"
					href={homePath(alt)}
					hreflang={alt}
					lang={alt}
				>
					{langToggleLabel}
				</a>
				<SocialLinks variant="header" ariaLabel={a.navSocial} />
			</div>
		</div>
	</div>

	<div class="mobile-menu-backdrop lg:hidden" data-mobile-menu-backdrop data-open="false"></div>

	<div
		id={menuId}
		class="mobile-menu border-t border-white/10 px-[clamp(1rem,4vw,2rem)] py-5 lg:hidden"
		data-mobile-menu
		data-open="false"
	>
		<nav aria-label={a.navPrimary}>
			<ul class="m-0 grid list-none gap-2 p-0">
				{
					links.map(({ href: h, label }) => (
						<li>
							<a
								class="inline-flex min-h-12 w-full items-center rounded-md border border-ut-bg/10 bg-ut-bg/[0.03] px-4 text-[0.8125rem] font-semibold uppercase tracking-wide text-ut-bg/90 no-underline transition hover:border-ut-bg/20 hover:bg-ut-bg/10 hover:text-ut-bg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ut-scampi"
								href={h}
								data-mobile-menu-link
							>
								{label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
		<div class="mt-4 flex items-center justify-between gap-3 border-t border-white/10 pt-4">
			<a
				class="inline-flex min-h-11 items-center rounded-md border border-ut-bg/10 bg-ut-bg/[0.03] px-3 text-[0.75rem] font-semibold uppercase tracking-wide text-ut-hero-tonal no-underline transition hover:border-ut-bg/20 hover:bg-ut-bg/10 hover:text-ut-bg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ut-scampi"
				href={homePath(alt)}
				hreflang={alt}
				lang={alt}
				data-mobile-menu-link
			>
				{langToggleLabel}
			</a>
			<SocialLinks variant="header" ariaLabel={a.navSocial} />
		</div>
	</div>
</header>

<script>
	(() => {
		document.querySelectorAll('[data-site-header]').forEach((rootHeader) => {
			if (!(rootHeader instanceof HTMLElement)) return;

			const toggleButton = /** @type {HTMLButtonElement | null} */ (
				rootHeader.querySelector('[data-mobile-menu-button]')
			);
			const mobileMenu = /** @type {HTMLElement | null} */ (rootHeader.querySelector('[data-mobile-menu]'));
			const mobileBackdrop = /** @type {HTMLElement | null} */ (
				rootHeader.querySelector('[data-mobile-menu-backdrop]')
			);
			if (
				!(toggleButton instanceof HTMLButtonElement) ||
				!(mobileMenu instanceof HTMLElement) ||
				!(mobileBackdrop instanceof HTMLElement)
			) {
				return;
			}

			const isOpen = () => mobileMenu.dataset.open === 'true';
			const focusableSelector =
				'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';
			const getFocusableMenuItems = () =>
				Array.from(mobileMenu.querySelectorAll(focusableSelector)).filter(
					(element) => element instanceof HTMLElement && !element.hasAttribute('disabled')
				);
			const openMenu = () => {
				mobileMenu.dataset.open = 'true';
				mobileBackdrop.dataset.open = 'true';
				toggleButton.setAttribute('aria-expanded', 'true');
				const nextLabel = toggleButton.dataset.closeLabel;
				if (nextLabel) toggleButton.setAttribute('aria-label', nextLabel);
				const [firstElement] = getFocusableMenuItems();
				if (firstElement instanceof HTMLElement) {
					firstElement.focus();
				}
			};
			const closeMenu = () => {
				mobileMenu.dataset.open = 'false';
				mobileBackdrop.dataset.open = 'false';
				toggleButton.setAttribute('aria-expanded', 'false');
				const nextLabel = toggleButton.dataset.openLabel;
				if (nextLabel) toggleButton.setAttribute('aria-label', nextLabel);
			};
			closeMenu();

			toggleButton.addEventListener('click', () => {
				if (isOpen()) {
					closeMenu();
				} else {
					openMenu();
				}
			});

			mobileMenu.querySelectorAll('[data-mobile-menu-link]').forEach((link) => {
				link.addEventListener('click', closeMenu);
			});
			mobileBackdrop.addEventListener('click', closeMenu);

			rootHeader.addEventListener('keydown', (event) => {
				if (event.key === 'Escape' && isOpen()) {
					closeMenu();
					toggleButton.focus();
				}

				if (event.key === 'Tab' && isOpen()) {
					const focusable = getFocusableMenuItems();
					if (focusable.length === 0) return;
					const first = focusable[0];
					const last = focusable[focusable.length - 1];
					const activeElement = document.activeElement;

					if (event.shiftKey && activeElement === first) {
						event.preventDefault();
						if (last instanceof HTMLElement) last.focus();
					} else if (!event.shiftKey && activeElement === last) {
						event.preventDefault();
						if (first instanceof HTMLElement) first.focus();
					}
				}
			});

			const breakpoint = window.matchMedia('(min-width: 1024px)');
			const onBreakpointChange = () => {
				if (breakpoint.matches) {
					closeMenu();
				}
			};
			onBreakpointChange();
			breakpoint.addEventListener('change', onBreakpointChange);
		});
	})();
</script>

<style>
	.mobile-menu-backdrop {
		position: fixed;
		inset: 0;
		top: 3.75rem;
		background: rgba(29, 29, 29, 0.55);
		opacity: 0;
		pointer-events: none;
		transition: opacity 200ms ease;
	}

	.mobile-menu-backdrop[data-open='true'] {
		opacity: 1;
		pointer-events: auto;
	}

	.mobile-menu {
		position: absolute;
		left: 0;
		right: 0;
		top: 100%;
		background: rgba(29, 29, 29, 0.98);
		box-shadow: 0 20px 30px rgba(29, 29, 29, 0.4);
		max-height: calc(100vh - 3.75rem);
		overflow-y: auto;
		opacity: 0;
		transform: translateY(-0.5rem);
		pointer-events: none;
		transition: opacity 200ms ease, transform 200ms ease;
	}

	.mobile-menu[data-open='true'] {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}

	.menu-button-icon {
		display: inline-flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.menu-button-icon span {
		display: block;
		width: 1.25rem;
		height: 2px;
		border-radius: 999px;
		background: currentColor;
		transition: transform 160ms ease, opacity 160ms ease;
	}

	.mobile-menu-button[aria-expanded='true'] .menu-button-icon span:nth-child(1) {
		transform: translateY(6px) rotate(45deg);
	}

	.mobile-menu-button[aria-expanded='true'] .menu-button-icon span:nth-child(2) {
		opacity: 0;
	}

	.mobile-menu-button[aria-expanded='true'] .menu-button-icon span:nth-child(3) {
		transform: translateY(-6px) rotate(-45deg);
	}

	@media (prefers-reduced-motion: reduce) {
		.mobile-menu,
		.mobile-menu-backdrop,
		.menu-button-icon span {
			transition: none;
		}
	}
</style>
