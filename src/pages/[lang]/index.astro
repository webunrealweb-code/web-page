---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/layout/SiteHeader.astro';
import SiteFooter from '../../components/layout/SiteFooter.astro';
import Hero from '../../components/sections/Hero.astro';
import StatsGrid from '../../components/sections/StatsGrid.astro';
import AboutBand from '../../components/sections/AboutBand.astro';
import ServicesBand from '../../components/sections/ServicesBand.astro';
import PartnersBand from '../../components/sections/PartnersBand.astro';
import ContactBand from '../../components/sections/ContactBand.astro';
import PartnerCampaignsBand from '../../components/sections/PartnerCampaignsBand.astro';
import { talentRoster, brandLogos } from '../../data/homepage';
import { getMessages, type Lang } from '../../i18n';
import { homePath, isLang, langs } from '../../i18n/paths';

export function getStaticPaths() {
	return langs.map((lang) => ({ params: { lang } }));
}

const { lang: langParam } = Astro.params;
if (!isLang(langParam ?? '')) {
	return Astro.redirect('/en/', 302);
}
const lang = langParam as Lang;
const messages = getMessages(lang);

const canonicalPath = homePath(lang);
---

<BaseLayout
	title={messages.meta.title}
	description={messages.meta.description}
	lang={lang}
	ogLocale={messages.ogLocale}
	canonicalPath={canonicalPath}
	skipLinkText={messages.a11y.skipToMain}
>
	<SiteHeader lang={lang} messages={messages} />
	<main id="main-content" tabindex="-1">
		<Hero lang={lang} messages={messages} />
		<StatsGrid stats={messages.statsLabels} ariaLabel={messages.a11y.statsRegion} />
		<AboutBand messages={messages} />
		<ServicesBand talents={talentRoster} messages={messages} />
		<PartnerCampaignsBand messages={messages} />
		<PartnersBand brandLogos={brandLogos} messages={messages} />
		<ContactBand messages={messages} />
	</main>
	<SiteFooter lang={lang} messages={messages} />
</BaseLayout>
